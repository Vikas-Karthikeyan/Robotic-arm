#include <Servo.h>

#define IR_SENSOR_PIN 2  // IR sensor connected to pin 2
#define BASE_SERVO_PIN 9  // Base rotation servo
#define GRIPPER_SERVO_PIN 6  // Gripper servo
#define SHOULDER_SERVO_PIN 11 // Base rotation servo
#define ELBOW_SERVO_PIN 10  // Gripper servo
#define red_led 4
#define blue_led 7
#define yellow_led 8

Servo baseServo;   // Base rotation
Servo gripperServo; // Gripper
Servo shoulderServo;
Servo elbowServo;

const int BASE_MIN_ANGLE = 0;   // Minimum position of base
const int BASE_MAX_ANGLE = 60; // Maximum position of base
const int GRIPPER_OPEN = 20;   // Gripper open position
const int GRIPPER_CLOSE = 110;  // Gripper closed position
const int SHOULDER_MIN = 90;   // Gripper open position
const int SHOULDER_MAX = 120;  // Gripper closed position
const int ELBOW_MIN = 90;   // Gripper open position
const int ELBOW_MAX = 120;  // Gripper closed position

char receivedColor = 'N'; // Default 'N' = No color detected

void setup() {
    Serial.begin(9600);  // Start Serial communication
    pinMode(IR_SENSOR_PIN, INPUT);  // IR sensor as input
    baseServo.attach(BASE_SERVO_PIN);
    gripperServo.attach(GRIPPER_SERVO_PIN);
    shoulderServo.attach(SHOULDER_SERVO_PIN);
    elbowServo.attach(ELBOW_SERVO_PIN);
    pinMode(red_led, OUTPUT);
    pinMode(blue_led, OUTPUT);
    pinMode(yellow_led, OUTPUT);

    // Set initial positions
    baseServo.write(BASE_MIN_ANGLE);  
    gripperServo.write(GRIPPER_OPEN); 
    elbowServo.write(180); 
    Serial.println("Waiting for object...");
}

void loop() {
    // Check if data is available from Python
    if (Serial.available() > 0) {
      receivedColor = Serial.read();  // Read color character from Python

           // ✅ Read until a valid character is received
      if (receivedColor == 'R' || receivedColor == 'Y' || receivedColor == 'B') {
        Serial.print("Received Color: ");
        Serial.println(receivedColor);
      }
    }

    int sensorValue = digitalRead(IR_SENSOR_PIN);  // Read IR sensor

    if (sensorValue == LOW) {  // Object detected
        
        Serial.println("Object Detected! Picking up...");

        gripperServo.write(GRIPPER_CLOSE);  // Close gripper
        delay(1000);

        arm_up();

        // Move based on detected color
        if (receivedColor == 'R') {  // Red
            //digitalWrite(red_led, HIGH);
            moveServoSlowly(baseServo, BASE_MIN_ANGLE, 60, 20); 
            //digitalWrite(red_led, LOW);
        } else if (receivedColor == 'Y') {  // Green
            //digitalWrite(yellow_led, HIGH);
            moveServoSlowly(baseServo, BASE_MIN_ANGLE, 120, 20);
            //digitalWrite(yellow_led, LOW);
        } else if (receivedColor == 'B') {  // Blue
            //digitalWrite(blue_led, HIGH);
            moveServoSlowly(baseServo, BASE_MIN_ANGLE, 180, 20);
            //digitalWrite(blue_led, LOW);
        }/* else {
            moveServoSlowly(baseServo, BASE_MIN_ANGLE, BASE_MAX_ANGLE, 10);
        } */
        delay(500);
        gripperServo.write(GRIPPER_OPEN);  // Release object
        delay(1000);

        Serial.println("Returning to start position..."); 
        moveServoSlowly(baseServo, BASE_MAX_ANGLE, BASE_MIN_ANGLE, 30);

        arm_down();
        Serial.println("END"); 
    }
}

// Function to move servo slowly
void moveServoSlowly(Servo &servo, int startAngle, int endAngle, int speedDelay) {
    if (startAngle < endAngle) {
        for (int pos = startAngle; pos <= endAngle; pos++) {
            servo.write(pos);
            delay(speedDelay);
        }
    } else {
        for (int pos = startAngle; pos >= endAngle; pos--) {
            servo.write(pos);
            delay(speedDelay);
        }
    }
}

void arm_up(){
  delay(1000);
  Serial.println("moving elbow from 120-180...");
  moveServoSlowly(elbowServo,120,180,20);
  delay(1000);
  Serial.println("moving shoulder from 135-80...");
  moveServoSlowly(shoulderServo,150,80,20);
  delay(1000);
}

void arm_down(){
  delay(1000);
  Serial.println("moving shoulder from 80-125...");
  moveServoSlowly(shoulderServo,80,150,20);
  delay(1000);
  Serial.println("moving elbow from 180-120...");
  moveServoSlowly(elbowServo,180,120,20);
  delay(1000);
}
